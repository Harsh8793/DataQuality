# ==========================================================
#  DataPilot AI — environment variables (EXAMPLE, safe to commit)
#  Copy this to  backend/.env  and fill in real values.
#  NEVER commit your real .env (it is git-ignored).
# ==========================================================

# ---- Application ----
APP_NAME="DataPilot AI"
APP_ENV=development                 # use "production" in deploys
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# ---- CORS (comma-separated origins; not needed for the single-container deploy) ----
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Security / JWT ----
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---- Database & storage (SQLite + parquet on disk) ----
DATABASE_URL=sqlite:///./data/datapilot.db
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
PARQUET_DIR=./data/parquet
REPORT_DIR=./data/reports
CHROMA_DIR=./data/chroma

# ---- Upload limits ----
MAX_UPLOAD_MB=50
ALLOWED_EXTENSIONS=csv,xlsx,xls,json

# ---- Groq / LLM (get a free key at https://console.groq.com) ----
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1500
LLM_ENABLED=true
